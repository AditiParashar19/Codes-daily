class Solution {
public:
    vector<int> findThePrefixCommonArray(vector<int>& A, vector<int>& B) {
        //we keep only a one array to keep track of visited elements as it appear only once in both arrays
        //common increases when frequency of element become 2 so it means element occurs twice
        int n = A.size();
        vector<int>freq(n+1,0);
        vector<int>res(n);
        int common = 0;
        for(int i=0;i<n;i++){
            freq[A[i]]++;
            if(freq[A[i]]==2)  common++;
            
            freq[B[i]]++;
            if(freq[B[i]]==2)  common++;
            res[i]  = common;
        }
        return res;
    }
};
