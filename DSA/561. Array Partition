class Solution {
public:
    int arrayPairSum(vector<int>& nums) {
        sort(nums.begin(),nums.end());
        int sum = 0;
        for(int i=0;i<nums.size();i+=2){
            sum+=nums[i];
        }
        return sum;
    }
};

Time Complexity : O(NlogN)

It forms pair [1,2,3,4]
min(1,2) + min(3,4) = 1 + 3 = 4 
1) Sort the Array
2) make pairs - add first element and leave second element
