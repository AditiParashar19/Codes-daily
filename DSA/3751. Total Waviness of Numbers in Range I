// Brute Force Approach 

class Solution {
public:
    int waviness(int x){
            string s = to_string(x);
            int cnt = 0;
            if(s.size()<3)
                return 0;
                for(int i=1;i<s.size()-1;i++){
                    if((s[i-1]<s[i] && s[i]>s[i+1]) || (s[i-1]>s[i] && s[i+1]> s[i]))
                        cnt++;
                }
            return cnt;
    }
    int totalWaviness(int num1, int num2) {
        int c = 0;
        for(int i=num1;i<=num2;i++){
            c+=waviness(i);
        }
        return c;
    }
};
