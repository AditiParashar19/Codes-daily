class Solution {
public:
    bool canJump(vector<int>& nums) {
        int maxReach =0 ;
        int j=0;
        if(nums.size()==1)
            return true;
        while(j!=nums.size()){
             if(maxReach<j)
            {
            return false;
            }
            maxReach = max(maxReach,j+nums[j]);
            j++;
        }
        return true;
        
    }
};
