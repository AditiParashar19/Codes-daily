class Solution {
public:
    vector<int> separateDigits(vector<int>& nums) {
        vector<int>res;
        for(int i=0;i<nums.size();i++){
            string s = to_string(nums[i]);
            for(char k : s){
                res.push_back(k-'0');
            }
        }
        return res;
    }
};
