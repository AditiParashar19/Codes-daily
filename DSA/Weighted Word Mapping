class Solution {
public:
    string mapWordWeights(vector<string>& words, vector<int>& weights) {
        string str1="";
        for(int i=0;i<words.size();i++){
            int sum1 = 0;
            for(char ch : words[i]){
                sum1+=weights[ch-'a'];
            }
            sum1 = sum1%26;
            char c = 'z'-sum1;
            str1+=c;
        }
        return str1;
    }
};
