class Solution {
public:
    int numOfSubarrays(vector<int>& arr, int k, int threshold) {
        int cnt =0;
        int n = arr.size();
        int max_sum = 0;
        double avg = 0.0;
        for(int i=0;i<k;i++){
            max_sum+=arr[i];
        }
        if(max_sum/k>=threshold){
            avg = max_sum/k;
            cnt++;
        }
        for(int i=k;i<n;i++){
            max_sum+=arr[i];
            max_sum-=arr[i-k];
            avg = max_sum/k;
            if(avg>=threshold)
                    cnt++;
        }
        return cnt;
    }
};
