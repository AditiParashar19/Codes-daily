### Time Complexity = O(N)
class Solution {
public:
    int findMin(vector<int>& nums) {
        int index = 0;
        for(int i=0;i<nums.size()-1;i++){
            if(nums[i]>nums[i+1])
                index = i+1;
        }
        return nums[index];
    }
};

### Time Complexity = O(logN)
#### Binary Search 

class Solution {
public:
    int findMin(vector<int>& nums) {
        int n=nums.size();
        int low=0;
        int high=n-1;
        int ans=INT_MAX;
        while(low<=high){
            int mid=(low+high)/2;
            if(nums[low]<=nums[mid]){
                ans=min(ans,nums[low]);
                low=mid+1;
            } else {
                ans=min(ans,nums[mid]);
                high=mid-1;
                }
            }
            return ans;
    }
};
