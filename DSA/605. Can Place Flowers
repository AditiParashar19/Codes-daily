class Solution {
public:
    bool canPlaceFlowers(vector<int>& flowerbed, int n) {
        for(int i=0;i<flowerbed.size();i++){
           if(flowerbed[i]==0){
            int l = (i==0)?0:flowerbed[i-1];
            int r = (i==flowerbed.size()-1)? 0:flowerbed[i+1];
            if(l==0 && r==0){
                flowerbed[i] = 1;
                n--;
            }  
        }
    }
    return n<=0;
    }
};
