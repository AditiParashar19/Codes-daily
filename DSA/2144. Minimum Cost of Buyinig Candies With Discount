class Solution {
public:
    int minimumCost(vector<int>& cost) {
        sort(cost.begin(),cost.end());
        int t = 0;
    //When array sorted in descending order
    //    for(int i=0;i<cost.size();i++){
    //     if((i+1)%3!=0)
    //         t+=cost[i];
    //    }
    //    return t;
    // When array is sorted in ascending order
    for(int i=cost.size()-1;i>=0;i=i-3){
        if(i-1>=0) t+=cost[i] + cost[i-1];
        else t+=cost[i];
    }
    return t;
    }
};
