class Solution {
public:
    int findMin(vector<int>& nums) {
        int l = 0,r = nums.size()-1;
        while(l<=r){
            int mid = l+(r-l)/2;
            if(nums[mid]>nums[r])
                l = mid+1;
            else if(nums[mid]<nums[r])
                r = mid;
            else
                r--;
        }
        return nums[l];
    }
};

// Case 1: nums[mid] > nums[right]
The minimum lies to the right of mid because the left portion is properly sorted.

Case 2 : nums[mid] < nums[right]
The minimum is either at mid or on its left.
right = mid;
We keep mid because it could itself be the minimum.

Case 3 : nums[mid] == nums[right]
right--;
Why is this safe?
Because nums[right] == nums[mid]. Removing one occurrence of the same value cannot remove the unique minimum if it exists elsewhere.
